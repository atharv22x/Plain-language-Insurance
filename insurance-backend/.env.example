# Environment Variables for Plain-Language Insurance Backend
# Copy this file to .env and fill in your values

# Server Port (default: 3001)
PORT=3001

# HuggingFace API Key (FREE - get at https://huggingface.co/settings/tokens)
# Without this, the backend uses smart keyword-based analysis (still works great for demo)
HF_API_KEY=hf_your_key_here
